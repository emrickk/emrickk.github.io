{
  "name": "theneverless",
  "description": "NeVeRtheLeSs, a bilingual personal blog since 2005. Built with Astro and the astro-tone theme.",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "author": "NeVeRtheLeSs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emrickk/emrickk.github.io.git"
  },
  "bugs": {
    "url": "https://github.com/emrickk/emrickk.github.io/issues"
  },
  "homepage": "https://theneverless.com",
  "keywords": [
    "astro",
    "blog",
    "personal-blog",
    "bilingual",
    "markdown",
    "pagefind"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && pagefind --site dist",
    "preview": "astro preview",
    "preview-posts": "node scripts/preview-posts.mjs",
    "astro": "astro",
    "check": "astro check",
    "format": "prettier --write \"src/**/*.{astro,ts,css,md,mdx}\"",
    "lint": "eslint \"src/**/*.{js,ts,astro}\" \"*.mjs\"",
    "lint:css": "stylelint \"src/**/*.{css,astro}\"",
    "images": "node scripts/images/process.mjs",
    "images:migrate": "node scripts/images/migrate.mjs",
    "test:images": "node --test \"scripts/images/*.test.mjs\"",
    "test:rehype": "node --test \"scripts/rehype/*.test.mjs\"",
    "test:editor": "node --test scripts/post-editor/api.test.mjs",
    "checkpoint": "node scripts/checkpoint.mjs",
    "release-check": "node scripts/release-check.mjs",
    "test:safety": "node --test scripts/checkpoint.test.mjs scripts/release-check.test.mjs scripts/preview-posts.test.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@aws-sdk/client-s3": "^3.1085.0",
    "astro": "^6.3.1",
    "astro-expressive-code": "^0.42.0",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "sharp": "^0.34.3",
    "toc-rail": "^0.1.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-astro": "^1.7.0",
    "pagefind": "^1.5.2",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "stylelint": "^17.11.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3"
  },
  "overrides": {
    "@typescript-eslint/scope-manager": "8.46.3",
    "@typescript-eslint/types": "8.46.3",
    "@typescript-eslint/visitor-keys": "8.46.3",
    "yaml-language-server": {
      "yaml": "2.8.4"
    }
  }
}
