---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import readingTimeLib from 'reading-time';
import PostLayout from '../../layouts/PostLayout.astro';
import { buildTranslationMap } from '../../utils/translations';

export async function getStaticPaths() {
  const allPosts = (await getCollection('posts'))
    .filter((p) => !p.data.draft)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  return allPosts.map((post) => {
    const slug = post.id;
    return {
      params: { slug },
      props: {
        post,
        relatedPosts: allPosts
          .filter((p) => p.id !== post.id)
          .sort((a, b) => {
            const sameCategoryA = a.data.category && a.data.category === post.data.category ? 1 : 0;
            const sameCategoryB = b.data.category && b.data.category === post.data.category ? 1 : 0;
            if (sameCategoryA !== sameCategoryB) return sameCategoryB - sameCategoryA;
            return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
          })
          .slice(0, 3),
      },
    };
  });
}

interface Props {
  post: CollectionEntry<'posts'>;
  relatedPosts: CollectionEntry<'posts'>[];
}

const { post, relatedPosts } = Astro.props;
const orig = post.data.lang ?? 'zh';
const otherLang = orig === 'zh' ? 'en' : 'zh';

const { Content } = await render(post);

const tmap = await buildTranslationMap();
const sibling = post.data.translationKey
  ? tmap.get(`${post.data.translationKey}:${otherLang}`)
  : undefined;
const Sibling = sibling ? (await render(sibling)).Content : null;

const readingTime = Math.max(1, Math.round(readingTimeLib(post.body ?? '').minutes));
---

<PostLayout
  {...post.data}
  slug={post.id}
  readingTime={readingTime}
  focusEffect={post.data.focusEffect}
  relatedPosts={relatedPosts}
>
  {
    Sibling ? (
      <>
        <div class={`lang lang-${orig}`} data-orig>
          <Content />
        </div>
        <div class={`lang lang-${otherLang}`}>
          <Sibling />
        </div>
      </>
    ) : (
      <Content />
    )
  }
</PostLayout>
