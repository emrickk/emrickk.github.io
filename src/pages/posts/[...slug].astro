---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import readingTimeLib from 'reading-time';
import PostLayout from '../../layouts/PostLayout.astro';
import { buildTranslationMap } from '../../utils/translations';

export async function getStaticPaths() {
  const allPosts = (await getCollection('posts'))
    .filter((p) => !p.data.draft)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  return allPosts.map((post, index) => {
    const slug = post.id;
    return {
      params: { slug },
      props: {
        post,
        // allPosts is sorted newest-first, so neighbors are chronological.
        newerPost: allPosts[index - 1],
        olderPost: allPosts[index + 1],
        relatedPosts: allPosts
          .filter((p) => p.id !== post.id)
          .sort((a, b) => {
            const sameCategoryA = a.data.category && a.data.category === post.data.category ? 1 : 0;
            const sameCategoryB = b.data.category && b.data.category === post.data.category ? 1 : 0;
            if (sameCategoryA !== sameCategoryB) return sameCategoryB - sameCategoryA;
            // Within the category, prefer posts closest in time to this one so
            // every post gets its own trio instead of the category's newest 3.
            const distA = Math.abs(a.data.pubDate.valueOf() - post.data.pubDate.valueOf());
            const distB = Math.abs(b.data.pubDate.valueOf() - post.data.pubDate.valueOf());
            return distA - distB;
          })
          .slice(0, 3),
      },
    };
  });
}

interface Props {
  post: CollectionEntry<'posts'>;
  relatedPosts: CollectionEntry<'posts'>[];
  olderPost?: CollectionEntry<'posts'>;
  newerPost?: CollectionEntry<'posts'>;
}

const { post, relatedPosts, olderPost, newerPost } = Astro.props;
const orig = post.data.lang ?? 'zh';
const otherLang = orig === 'zh' ? 'en' : 'zh';

const { Content } = await render(post);

const tmap = await buildTranslationMap();
const sibling = post.data.translationKey
  ? tmap.get(`${post.data.translationKey}:${otherLang}`)
  : undefined;
const Sibling = sibling ? (await render(sibling)).Content : null;

// A protected post and its translation must both carry the flag: each file
// declares it in its own frontmatter so the content-layer cache invalidates
// correctly, and this guard fails the build before a half-flagged pair can
// ship one body as plaintext.
if (sibling && post.data.protected !== sibling.data.protected) {
  throw new Error(
    `Protected flag mismatch for "${post.id}": set protected: true in both the primary post and its ${otherLang} sibling, or in neither.`
  );
}

const readingTime = Math.max(1, Math.round(readingTimeLib(post.body ?? '').minutes));
---

<PostLayout
  {...post.data}
  slug={post.id}
  readingTime={readingTime}
  focusEffect={post.data.focusEffect}
  relatedPosts={relatedPosts}
  olderPost={olderPost}
  newerPost={newerPost}
>
  {
    Sibling ? (
      <>
        <div class={`lang lang-${orig}`} data-orig>
          <Content />
        </div>
        <div class={`lang lang-${otherLang}`}>
          <Sibling />
        </div>
      </>
    ) : (
      <Content />
    )
  }
</PostLayout>
