---
import '../styles/pages/home.css';
import type { ImageMetadata } from 'astro';
import { Image, getImage } from 'astro:assets';
import { getCollection } from 'astro:content';
import FeaturedPostGrid from '../components/FeaturedPostGrid.astro';
import FormattedDate from '../components/FormattedDate.astro';
import LangTitle from '../components/LangTitle.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  DATE_LOCALE,
  SITE_TITLE,
  SITE_DESCRIPTION,
  SITE_DESCRIPTION_ZH,
  SITE_DESCRIPTION_EN,
} from '../consts';
import { getUiText } from '../ui';
import { withBase } from '../utils/paths';
const tr = getUiText();

const posts = (await getCollection('posts'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Every post flagged `homeFeatured` gets a featured card; without flags the
// single most recent post fills the section.
const flaggedFeatured = posts.filter((post) => post.data.homeFeatured);
const featuredPosts = flaggedFeatured.length > 0 ? flaggedFeatured : posts.slice(0, 1);
const featuredIds = new Set(featuredPosts.map((post) => post.id));
const heroCandidates = posts.filter((post) => !featuredIds.has(post.id));
const pinnedHeroPosts = posts
  .filter((post) => !featuredIds.has(post.id) && post.data.homeHeroOrder)
  .sort((a, b) => {
    const orderDelta = (a.data.homeHeroOrder ?? 0) - (b.data.homeHeroOrder ?? 0);
    if (orderDelta !== 0) return orderDelta;
    return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  });
const fallbackHeroPosts = heroCandidates.filter((post) => !post.data.homeHeroOrder);
const heroPosts = [...pinnedHeroPosts, ...fallbackHeroPosts].slice(0, 2);
const heroDateFormatter = new Intl.DateTimeFormat(DATE_LOCALE, {
  year: 'numeric',
  month: 'short',
  day: '2-digit',
});
const heroDateFormatterEn = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const getHeroDateParts = (date: Date) => ({
  zhParts: heroDateFormatter.formatToParts(date),
  enParts: heroDateFormatterEn.formatToParts(date),
});
const gridCandidates = posts.filter((post) => !featuredIds.has(post.id));
const pinnedGridPosts = gridCandidates
  .filter((post) => post.data.homeOrder)
  .sort((a, b) => {
    const orderDelta = (a.data.homeOrder ?? 0) - (b.data.homeOrder ?? 0);
    if (orderDelta !== 0) return orderDelta;
    return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  });
const fallbackGridPosts = gridCandidates.filter((post) => !post.data.homeOrder);
const gridPosts = [...pinnedGridPosts, ...fallbackGridPosts].slice(0, 3);
const featuredPlaceholderEntries = await Promise.all(
  featuredPosts.map(
    async (post) =>
      [
        post.id,
        post.data.heroImage
          ? (
              await getImage({
                src: post.data.heroImage,
                width: 48,
                format: 'webp',
                quality: 28,
              })
            ).src
          : undefined,
      ] as const
  )
);
const featuredPlaceholderById = new Map<string, string | undefined>(featuredPlaceholderEntries);
const featuredPlaceholderStyle = (id: string) => {
  const src = featuredPlaceholderById.get(id);
  return src ? `--tone-image-placeholder: url("${src}");` : undefined;
};
// The thumb column is 360px wide but crops with object-fit: cover in a 6/7
// box, so the image renders at the box height (420px) times the source
// aspect. `sizes` must report that effective width, not the column width,
// or retina screens get an upscaled srcset variant.
const featuredThumbSizes = (img: ImageMetadata) =>
  `(max-width: 600px) calc(100vw - 32px), ${Math.round(420 * Math.max(6 / 7, img.width / img.height))}px`;
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <main id="main-content" class="home-main">
    <section class="hero">
      <h1 class="hero-title">
        <span class="hero-title-line">{tr.heroTitle}</span>
        {
          tr.heroTitleLine2 && (
            <span class="hero-title-line hero-title-line--accent">{tr.heroTitleLine2}</span>
          )
        }
      </h1>

      <p class="hero-desc">
        <span class="lang lang-zh" data-orig>{SITE_DESCRIPTION_ZH}</span><span
          class="lang lang-en">{SITE_DESCRIPTION_EN}</span>
      </p>

      <div class="hero-divider" aria-hidden="true"></div>

      {
        heroPosts.length > 0 && (
          <nav class="hero-recent" aria-label="Selected posts">
            <div class="hero-recent-list">
              {
                heroPosts.map((post) => {
                  const heroDate = getHeroDateParts(post.data.pubDate);

                  return (
                    <a href={withBase(`/posts/${post.id}/`)} class="hero-recent-item">
                      <span class="hero-recent-main">
                        <LangTitle
                          tag="span"
                          class="hero-recent-title"
                          zh={post.data.titleZh}
                          en={post.data.titleEn}
                          orig={post.data.lang ?? 'zh'}
                          fallback={post.data.title}
                        />
                        <span class="hero-recent-arrow" aria-hidden="true">
                          ↗
                        </span>
                      </span>
                      <span class="hero-recent-date">
                        <time datetime={post.data.pubDate.toISOString()}>
                          <span class="lang lang-zh" data-orig>{
                            heroDate.zhParts.map((part) => (
                              <span class={`hero-recent-date-${part.type}`}>{part.value}</span>
                            ))
                          }</span><span class="lang lang-en">{
                            heroDate.enParts.map((part) => (
                              <span class={`hero-recent-date-${part.type}`}>{part.value}</span>
                            ))
                          }</span>
                        </time>
                      </span>
                    </a>
                  );
                })
              }
            </div>
          </nav>
        )
      }
    </section>

    {
      featuredPosts.length > 0 && (
        <section class="featured-section">
          {featuredPosts.map((post) => (
            <a
              href={withBase(`/posts/${post.id}/`)}
              class:list={['featured-card', !post.data.heroImage && 'featured-card--text']}
            >
              <div class="featured-text">
                <p class="featured-meta">
                  <FormattedDate date={post.data.pubDate} />
                </p>
                <LangTitle
                  tag="h2"
                  class="featured-title"
                  zh={post.data.titleZh}
                  en={post.data.titleEn}
                  orig={post.data.lang ?? 'zh'}
                  fallback={post.data.title}
                />
                {post.data.description && <p class="featured-desc">{post.data.description}</p>}
                <span class="featured-cta">{tr.readLink}</span>
              </div>
              {post.data.heroImage && (
                <div class="featured-thumb-wrap" style={featuredPlaceholderStyle(post.id)}>
                  <Image
                    src={post.data.heroImage}
                    alt={post.data.title}
                    class="featured-thumb"
                    widths={[400, 720, 960, 1280, 1600]}
                    sizes={featuredThumbSizes(post.data.heroImage)}
                    quality={88}
                    loading="lazy"
                  />
                </div>
              )}
            </a>
          ))}
        </section>
      )
    }

    {
      gridPosts.length > 0 && (
        <section class="posts-section">
          <div class="posts-header">
            <a href={withBase('/posts')} class="view-all">
              {tr.viewAll}
            </a>
          </div>
          <FeaturedPostGrid posts={gridPosts} />
        </section>
      )
    }
  </main>
</BaseLayout>
