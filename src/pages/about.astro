---
import '../styles/pages/about.css';
import config from '../../astro-theme-config';
import LangText from '../components/LangText.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const profileImageUrl = config.about.profileImage.trim();
const hasProfileImage = profileImageUrl.length > 0;
const profileName = config.about.name || config.site.author;
const profileRole = config.about.role;
const profileLocation = config.about.location;
const profileFocus = config.about.focus;
const profileLead = config.about.lead;
const [headlineFirst, headlineSecond] = config.about.headline;
const statementLabel = config.about.statementLabel;
const statementTitle = config.about.statementTitle;
const statement = config.about.statement;
const careerLabel = config.about.careerLabel;
const careerItems = config.about.career;
const focusItems = config.about.interests;
const interestsLabel = config.about.interestsLabel;
const interestsHeading = config.about.interestsHeading;
const profileLinks = [
  {
    label: 'GitHub',
    href: config.social.github,
  },
  {
    label: 'Website',
    href: config.social.website,
  },
  {
    label: 'LinkedIn',
    href: config.social.linkedin,
  },
  {
    label: 'Email',
    href: config.social.email ? `mailto:${config.social.email}` : '',
  },
].filter((link) => link.href);
---

<BaseLayout title="About" description={`${profileLead.zh} · ${profileLead.en}`}>
  <main id="main-content" class="about-main">
    <section class="about-hero" aria-labelledby="about-title">
      <div class="about-intro">
        <h1 id="about-title" class="about-title">
          {headlineFirst}<br />
          {headlineSecond}
        </h1>
        <p class="about-lead">
          <LangText text={profileLead} />
        </p>
      </div>

      <aside
        class:list={['profile-panel', !hasProfileImage && 'profile-panel--text']}
        aria-label="Profile preview"
      >
        {
          hasProfileImage && (
            <figure class="profile-media">
              <img
                src={profileImageUrl}
                width="720"
                height="720"
                alt={`${profileName} profile portrait`}
                loading="eager"
                referrerpolicy="no-referrer"
              />
            </figure>
          )
        }
        <div class="profile-summary">
          <p class="profile-name">{profileName}</p>
          <p class="profile-role"><LangText text={profileRole} /></p>
        </div>
        <dl class="profile-meta">
          <div>
            <dt><LangText text={{ zh: '位置', en: 'Location' }} /></dt>
            <dd><LangText text={profileLocation} /></dd>
          </div>
          <div>
            <dt><LangText text={{ zh: '关注', en: 'Focus' }} /></dt>
            <dd><LangText text={profileFocus} /></dd>
          </div>
          {
            profileLinks.length > 0 && (
              <div>
                <dt>
                  <LangText text={{ zh: '链接', en: 'Links' }} />
                </dt>
                <dd class="profile-links">
                  {profileLinks.map((link) => (
                    <a
                      href={link.href}
                      target={link.href.startsWith('mailto:') ? undefined : '_blank'}
                      rel={link.href.startsWith('mailto:') ? undefined : 'noopener'}
                    >
                      {link.label}
                    </a>
                  ))}
                </dd>
              </div>
            )
          }
        </dl>
      </aside>
    </section>

    <section class="about-section about-statement" aria-labelledby="about-statement">
      <p class="section-label"><LangText text={statementLabel} /></p>
      <div>
        <h2 id="about-statement" class="section-heading">
          <LangText text={statementTitle} />
        </h2>
        <p><LangText text={statement} /></p>
      </div>
    </section>

    <section class="about-section" aria-label={careerLabel.en}>
      <p class="section-label"><LangText text={careerLabel} /></p>
      <div class="career-list">
        {
          careerItems.map((item) => (
            <article class="career-item">
              <time>
                <LangText text={item.period} />
              </time>
              <div>
                <h3>
                  <LangText text={item.title} />
                </h3>
                <p>
                  <LangText text={item.description} />
                </p>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="about-section" aria-labelledby="about-focus">
      <p class="section-label"><LangText text={interestsLabel} /></p>
      <div>
        <h2 id="about-focus" class="section-heading"><LangText text={interestsHeading} /></h2>
        <ul class="focus-list">
          {
            focusItems.map((item) => (
              <li>
                <LangText text={item} />
              </li>
            ))
          }
        </ul>
      </div>
    </section>
  </main>
</BaseLayout>
