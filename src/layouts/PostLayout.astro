---
import 'toc-rail/style.css';
import '../styles/layouts/post.css';
import type { CollectionEntry } from 'astro:content';
import ArchivedComments from '../components/ArchivedComments.astro';
import Comments from '../components/Comments.astro';
import FeaturedPostGrid from '../components/FeaturedPostGrid.astro';
import FormattedDate from '../components/FormattedDate.astro';
import LangTitle from '../components/LangTitle.astro';
import ImageLightbox from '../components/ImageLightbox.astro';
import ScrollFocus from '../components/ScrollFocus.astro';
import BaseLayout from './BaseLayout.astro';
import { SITE_AUTHOR, SITE_LANG, SITE_TITLE } from '../consts';
import { getUiText } from '../ui';
import { withBase } from '../utils/paths';
import { serializeScriptJson } from '../utils/serialize-script-json';

type Props = CollectionEntry<'posts'>['data'] & {
  slug?: string;
  readingTime?: number;
  relatedPosts?: CollectionEntry<'posts'>[];
  olderPost?: CollectionEntry<'posts'>;
  newerPost?: CollectionEntry<'posts'>;
};

const {
  slug,
  title,
  titleZh,
  titleEn,
  lang: origLang = 'zh',
  description,
  pubDate,
  updatedDate,
  heroImage,
  readingTime,
  focusEffect,
  relatedPosts = [],
  olderPost,
  newerPost,
} = Astro.props;

const tr = getUiText();
const postsBase = withBase('/posts');

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const pubDateISO = pubDate.toISOString();
const updatedDateISO = updatedDate?.toISOString();

const jsonLd = serializeScriptJson({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: pubDateISO,
  ...(updatedDateISO && { dateModified: updatedDateISO }),
  url: canonicalURL.href,
  ...(heroImage && { image: new URL(heroImage.src, Astro.site).href }),
  author: { '@type': 'Person', name: SITE_AUTHOR },
  publisher: { '@type': 'Organization', name: SITE_TITLE },
  inLanguage: SITE_LANG,
});
---

<BaseLayout
  title={title}
  description={description}
  image={heroImage}
  type="article"
  pubDate={pubDateISO}
  updatedDate={updatedDateISO}
  bodyClass="post-page"
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  {focusEffect && <ScrollFocus variant={focusEffect} />}

  <main id="main-content" class="post-main">
    <article data-pagefind-body>
      <a href={postsBase} class="back-link">{tr.backLink}</a>

      <header class="post-header">
        <div class="post-accent"></div>
        <div class="post-meta">
          <FormattedDate class="meta-date" date={pubDate} />
          {
            readingTime && (
              <>
                <span class="dot">·</span>
                <span class="meta-item">{tr.readingTime(readingTime)}</span>
              </>
            )
          }
          {
            updatedDate && (
              <>
                <span class="dot">·</span>
                <span class="meta-updated">
                  {tr.updated} <FormattedDate date={updatedDate} />
                </span>
              </>
            )
          }
        </div>
        <LangTitle
          tag="h1"
          class="post-title"
          zh={titleZh}
          en={titleEn}
          orig={origLang}
          fallback={title}
          meta={title}
        />
        {description && <p class="post-description">{description}</p>}
      </header>

      <div class="post-divider"></div>

      <div class="prose" id="prose-content">
        <slot />
      </div>

      {
        (olderPost || newerPost) && (
          <nav class="post-nav" aria-label={tr.postNav.label} data-pagefind-ignore="all">
            {olderPost && (
              <a href={`${postsBase}/${olderPost.id}/`} class="post-nav-card post-nav-older">
                <span class="post-nav-label">{tr.postNav.older}</span>
                <LangTitle
                  class="post-nav-title"
                  zh={olderPost.data.titleZh}
                  en={olderPost.data.titleEn}
                  orig={olderPost.data.lang ?? 'zh'}
                  fallback={olderPost.data.title}
                />
                <FormattedDate class="post-nav-date" date={olderPost.data.pubDate} />
              </a>
            )}
            {newerPost && (
              <a href={`${postsBase}/${newerPost.id}/`} class="post-nav-card post-nav-newer">
                <span class="post-nav-label">{tr.postNav.newer}</span>
                <LangTitle
                  class="post-nav-title"
                  zh={newerPost.data.titleZh}
                  en={newerPost.data.titleEn}
                  orig={newerPost.data.lang ?? 'zh'}
                  fallback={newerPost.data.title}
                />
                <FormattedDate class="post-nav-date" date={newerPost.data.pubDate} />
              </a>
            )}
          </nav>
        )
      }

      {
        relatedPosts.length > 0 && (
          <section class="related-section" data-pagefind-ignore="all">
            <div class="related-header">
              <p class="related-label">{tr.relatedPosts}</p>
              <a href={postsBase} class="related-view-all">
                {tr.allPosts}
              </a>
            </div>
            <FeaturedPostGrid posts={relatedPosts} variant="related" />
          </section>
        )
      }
    </article>
    {slug && <ArchivedComments slug={slug} />}
    <Comments />
  </main>
  <ImageLightbox />

  <script>
    import { mountReadingRailLoader } from '../scripts/reading-rail-loader';

    mountReadingRailLoader();
  </script>
</BaseLayout>
